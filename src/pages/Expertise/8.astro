---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Exterior Wall & Stucco Repair Minneapolis Twin Cities | HandyMSP">
    <div class="flex flex-col gap-12 sm:gap-16">

        <!-- HERO -->
        <section class="rounded-xl bg-gradient-to-br from-slate-800 to-slate-900 p-8 sm:p-12 text-center border border-slate-700">
            <p class="text-blue-400 font-semibold text-sm uppercase tracking-widest mb-3">
                Minneapolis &amp; Twin Cities Suburbs
            </p>
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
                Catch Stucco Cracks Before They Become Water Damage
            </h1>
            <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
                Exterior wall and stucco repair across the Twin Cities — seal cracks, restore surfaces, protect your investment.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="#quote"
                   class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-lg text-lg transition">
                    Get a Free Exterior Assessment
                </a>
                <a href="tel:7609721009"
                   class="inline-block bg-white hover:bg-slate-100 text-slate-900 font-bold px-8 py-4 rounded-lg text-lg transition">
                    &#128222; 760-972-1009
                </a>
            </div>
        </section>

        <!-- PAIN POINTS -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-8 text-center">Sound Familiar?</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
                <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                    <h3 class="font-bold text-white text-lg mb-2">Cracks are letting moisture in</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">Stucco cracks are not cosmetic — they're entry points for water. Minnesota's freeze-thaw cycle turns hairline cracks into major damage. Act early and save thousands.</p>
                </div>
                <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                    <h3 class="font-bold text-white text-lg mb-2">HOA violations and curb appeal</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">Cracked or patchy stucco triggers HOA letters and drops your home's value. We match texture and color so repairs are invisible.</p>
                </div>
                <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
                    <h3 class="font-bold text-white text-lg mb-2">More than stucco — full exterior repair</h3>
                    <p class="text-slate-300 text-sm leading-relaxed">We handle stucco, EIFS, fiber cement, wood siding, and exterior trim. One call covers your whole exterior.</p>
                </div>
            </div>
        </section>

        <!-- WHY HANDYMSP -->
        <section class="bg-slate-800 rounded-xl p-8 border border-slate-700">
            <h2 class="text-2xl font-bold text-white mb-6 text-center">
                Why Twin Cities Homeowners Choose HandyMSP
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex items-start gap-3">
                    <span class="text-green-400 font-bold text-lg flex-shrink-0">&#10003;</span>
                    <p class="text-slate-300 text-sm leading-relaxed">Serving Edina, Eden Prairie, Minnetonka, Plymouth, Wayzata, Hopkins, St. Louis Park, Bloomington, Burnsville, Eagan, Woodbury, Maple Grove &amp; all Twin Cities suburbs</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="text-green-400 font-bold text-lg flex-shrink-0">&#10003;</span>
                    <p class="text-slate-300 text-sm leading-relaxed">Licensed, insured &amp; background-checked technicians</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="text-green-400 font-bold text-lg flex-shrink-0">&#10003;</span>
                    <p class="text-slate-300 text-sm leading-relaxed">Same-week appointments available</p>
                </div>
                <div class="flex items-start gap-3">
                    <span class="text-green-400 font-bold text-lg flex-shrink-0">&#10003;</span>
                    <p class="text-slate-300 text-sm leading-relaxed">100% satisfaction guarantee — or we make it right</p>
                </div>
            </div>
        </section>

        <!-- WHAT WE HANDLE -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-6">What We Handle</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">Hairline and structural stucco crack repair</span>
                </div>
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">EIFS (synthetic stucco) patching and sealing</span>
                </div>
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">Exterior paint touch-up and texture matching</span>
                </div>
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">Wood siding replacement and repair</span>
                </div>
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">Caulking and sealing around windows and doors</span>
                </div>
                <div class="flex items-start gap-3 bg-slate-800 rounded-lg p-3 border border-slate-700">
                    <span class="text-blue-400 font-bold flex-shrink-0">&#10003;</span>
                    <span class="text-slate-300 text-sm">Trim and fascia board repair</span>
                </div>
            </div>
        </section>

        <!-- TESTIMONIAL -->
        <section class="border-l-4 border-blue-500 pl-6 py-2">
            <blockquote class="text-slate-200 text-lg italic mb-2">
                "They matched the stucco texture perfectly — you cannot tell where the repair is. Three neighbors have asked who did our work." — Patricia N., Edina
            </blockquote>
        </section>

        <!-- LEAD FORM -->
        <section id="quote" class="bg-slate-800 rounded-xl p-8 sm:p-10 border border-slate-700">
            <h2 class="text-2xl font-bold text-white mb-1">Schedule Your Free Exterior Inspection</h2>
            <p class="text-slate-400 mb-6">Free visit. No obligation. Same-week scheduling available.</p>
            <form name="stucco-exteriorrepair" method="POST" data-netlify="true" class="flex flex-col gap-4">
                <input type="hidden" name="form-name" value="stucco-exteriorrepair" />
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <input type="text"  name="name"  placeholder="Your Name"     required
                           class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:border-blue-500" />
                    <input type="tel"   name="phone" placeholder="Phone Number"  required
                           class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:border-blue-500" />
                </div>
                <input type="email" name="email"   placeholder="Email Address"   required
                       class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:border-blue-500" />
                <input type="text"  name="address" placeholder="Service Address (City + Zip)"
                       class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:border-blue-500" />
                <textarea name="description" placeholder="Describe what needs to be done..." rows="3" required
                          class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-400 focus:outline-none focus:border-blue-500 resize-none"></textarea>
                <select name="best-time"
                        class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-blue-500">
                    <option value="">Best time to call</option>
                    <option value="morning">Morning (7am&#8211;12pm)</option>
                    <option value="afternoon">Afternoon (12pm&#8211;5pm)</option>
                    <option value="evening">Evening (5pm&#8211;7pm)</option>
                </select>
                <button type="submit"
                        class="bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 px-8 rounded-lg text-lg transition self-start">
                    Schedule My Free Visit &#8594;
                </button>
            </form>
        </section>

        <!-- SECONDARY CTA -->
        <section class="text-center py-8 border-t border-slate-700">
            <h2 class="text-xl font-bold text-white mb-3">Spotted a crack? Call us before it gets worse.</h2>
            <a href="tel:7609721009"
               class="text-2xl font-bold text-blue-400 hover:text-blue-300 transition">
                760-972-1009
            </a>
            <p class="text-slate-400 mt-1">Available Mon&#8211;Sat, 7am&#8211;7pm</p>
            <p class="text-slate-500 text-sm mt-6">
                Serving Edina, Eden Prairie, Minnetonka, Plymouth, Wayzata, Hopkins,
                St.&nbsp;Louis Park, Bloomington, Burnsville, Eagan, Woodbury, Maple Grove
                &amp; all Twin Cities suburbs.
            </p>
        </section>

    </div>
</Layout>
