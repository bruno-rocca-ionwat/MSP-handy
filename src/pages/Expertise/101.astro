---
import Layout from '../../layouts/Layout.astro';

// ── Shared helper: natural filename sort ──────────────────────────────────────
function byFilename(pathA: string, pathB: string) {
  const name = (p: string) => p.split('/').pop() ?? p;
  return name(pathA).localeCompare(name(pathB), undefined, { numeric: true, sensitivity: 'base' });
}

// ── Carousel: all images in src/assets/expertise files/101 ───────────────────
const expertiseRaw = import.meta.glob<{ default: { src: string } }>(
  '../../assets/expertise files/101/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);
const expertiseImages = Object.entries(expertiseRaw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([, mod], i, arr) => ({
    src:   mod.default.src,
    label: `Flooring installation photo ${i + 1} of ${arr.length}`,
  }));
