---
import Layout from '../../layouts/Layout.astro';

/* =========================================================
   EDIT ONLY THIS LIST — title + caption for each image
   ---------------------------------------------------------
   Keys must match EXACT filenames in:
     /src/assets/expertise files/101/
   To hide overlay on an image, set title and caption to "".
   ========================================================= */
const texts: Record<string, { title: string; caption: string }> = {

  // ===== IMAGE: furniture-staining-05.png =====
  "furniture-staining-05.png": {
    title:   "Placeholder title for furniture-staining-05",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: furniture-staining-11.JPG =====
  "furniture-staining-11.JPG": {
    title:   "Placeholder title for furniture-staining-11",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: in-process1.jpg =====
  "in-process1.jpg": {
    title:   "Placeholder title for in-process1",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: interiorFloor-1.jpg =====
  "interiorFloor-1.jpg": {
    title:   "Placeholder title for interiorFloor-1",
    caption: "Placeholder caption describing what is happening in this image.",
  },

};
/* ===== END OF EDITABLE SECTION ===== */

function byFilename(pathA: string, pathB: string) {
  const name = (p: string) => p.split('/').pop() ?? p;
  return name(pathA).localeCompare(name(pathB), undefined, { numeric: true, sensitivity: 'base' });
}

const raw = import.meta.glob<{ default: { src: string } }>(
  '../../assets/expertise files/101/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const slides = Object.entries(raw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([path, mod]) => {
    const filename = path.split('/').pop() ?? path;
    const t = texts[filename] ?? { title: "", caption: "" };
    return { src: mod.default.src, filename, title: t.title, caption: t.caption };
  });

const captionsJSON = JSON.stringify(slides.map(s => ({ title: s.title, caption: s.caption })));
---
