/* =========================================================
   EDIT ONLY THIS LIST TO ADD / CHANGE TITLES + CAPTIONS
   ---------------------------------------------------------
   - Each { } block = ONE image in the carousel.
   - Order in this list = order in the carousel (top = first).
   - To add a new image: copy a block, paste it, edit the 3 fields.
   - To remove an image: delete its whole block including the comma.
   ========================================================= */

const slides = [

  // ===== IMAGE 1 =====
  {
    file:    "/images/photo1.jpg",
    title:   "Placeholder title for image 1",
    caption: "Placeholder caption describing what is happening in image 1.",
  },

  // ===== IMAGE 2 =====
  {
    file:    "/images/photo2.jpg",
    title:   "Placeholder title for image 2",
    caption: "Placeholder caption describing what is happening in image 2.",
  },

  // ===== IMAGE 3 =====
  {
    file:    "/images/photo3.jpg",
    title:   "Placeholder title for image 3",
    caption: "Placeholder caption describing what is happening in image 3.",
  },

  // ===== IMAGE 4 =====
  {
    file:    "/images/photo4.jpg",
    title:   "Placeholder title for image 4",
    caption: "Placeholder caption describing what is happening in image 4.",
  },

  // ===== IMAGE 5 =====
  {
    file:    "/images/photo5.jpg",
    title:   "Placeholder title for image 5",
    caption: "Placeholder caption describing what is happening in image 5.",
  },

  // ===== IMAGE 6 =====
  {
    file:    "/images/photo6.jpg",
    title:   "Placeholder title for image 6",
    caption: "Placeholder caption describing what is happening in image 6.",
  },

];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Expertise Carousel</title>
</head>
<body>

  <div class="carousel" id="carousel">
    {slides.map((s, i) => (
      <div class={"slide" + (i === 0 ? " active" : "")}>
        <img src={s.file} alt={s.title} />
        <div class="overlay">
          <h2>{s.title}</h2>
          <p>{s.caption}</p>
        </div>
      </div>
    ))}

    <button class="nav prev" onclick="change(-1)">&lsaquo;</button>
    <button class="nav next" onclick="change(1)">&rsaquo;</button>
    <div class="dots" id="dots"></div>
  </div>

  <script is:inline>
    // Carousel navigation logic — no need to edit this.
    let current = 0;
    const slidesEls = document.querySelectorAll(".slide");
    const dotsEl = document.getElementById("dots");

    slidesEls.forEach((_, i) => {
      const dot = document.createElement("div");
      dot.className = "dot" + (i === 0 ? " active" : "");
      dot.onclick = () => goTo(i);
      dotsEl.appendChild(dot);
    });

    function goTo(i) {
      const dots = document.querySelectorAll(".dot");
      slidesEls[current].classList.remove("active");
      dots[current].classList.remove("active");
      current = (i + slidesEls.length) % slidesEls.length;
      slidesEls[current].classList.add("active");
      dots[current].classList.add("active");
    }
    function change(dir) { goTo(current + dir); }

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") change(-1);
      if (e.key === "ArrowRight") change(1);
    });
  </script>

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #111;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .carousel {
      position: relative;
      width: 100%;
      max-width: 900px;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      background: #000;
    }
    .slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.6s ease;
    }
    .slide.active { opacity: 1; }
    .slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .overlay {
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      padding: 60px 32px 28px;
      background: linear-gradient(
        to top,
        rgba(0,0,0,0.85) 0%,
        rgba(0,0,0,0.6) 50%,
        rgba(0,0,0,0) 100%
      );
      color: #fff;
    }
    .overlay h2 {
      font-size: clamp(18px, 2.4vw, 26px);
      font-weight: 600;
      margin-bottom: 6px;
    }
    .overlay p {
      font-size: clamp(13px, 1.6vw, 16px);
      opacity: 0.9;
      line-height: 1.4;
    }
    .nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0,0,0,0.4);
      color: #fff;
      border: none;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      font-size: 22px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }
    .nav:hover { background: rgba(0,0,0,0.7); }
    .nav.prev { left: 16px; }
    .nav.next { right: 16px; }
    .dots {
      position: absolute;
      bottom: 14px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 8px;
      z-index: 2;
    }
    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.4);
      cursor: pointer;
      transition: background 0.2s;
    }
    .dot.active { background: #fff; }
  </style>

</body>
</html>
