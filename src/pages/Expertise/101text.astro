---
import Layout from '../../layouts/Layout.astro';

/* =========================================================
   EDIT ONLY THIS LIST — title + caption for each image
   ---------------------------------------------------------
   - Each KEY (in quotes) is the EXACT filename in:
       /src/assets/expertise files/101/
     Filenames are case-sensitive — match them exactly.
   - Each filename has a "title" and a "caption".
   - The carousel shows images in alphabetical order of their
     filenames (same as the folder listing).
   - To hide the overlay on an image, set its title and
     caption to empty strings "".
   ========================================================= */

const texts: Record<string, { title: string; caption: string }> = {

  // ===== IMAGE: furniture-staining-05.png =====
  "furniture-staining-05.png": {
    title:   "Placeholder title for furniture-staining-05",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: furniture-staining-11.JPG =====
  "furniture-staining-11.JPG": {
    title:   "Placeholder title for furniture-staining-11",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: in-process1.jpg =====
  "in-process1.jpg": {
    title:   "Placeholder title for in-process1",
    caption: "Placeholder caption describing what is happening in this image.",
  },

  // ===== IMAGE: interiorFloor-1.jpg =====
  "interiorFloor-1.jpg": {
    title:   "Placeholder title for interiorFloor-1",
    caption: "Placeholder caption describing what is happening in this image.",
  },

};

/* ===== END OF EDITABLE SECTION ===== */


// --- Below this line is the carousel engine — no need to edit ---

function byFilename(pathA: string, pathB: string) {
  const name = (p: string) => p.split('/').pop() ?? p;
  return name(pathA).localeCompare(name(pathB), undefined, { numeric: true, sensitivity: 'base' });
}

const raw = import.meta.glob<{ default: { src: string } }>(
  '../../assets/expertise files/101/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const slides = Object.entries(raw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([path, mod]) => {
    const filename = path.split('/').pop() ?? path;
    const t = texts[filename] ?? { title: "", caption: "" };
    return { src: mod.default.src, filename, title: t.title, caption: t.caption };
  });
---

<Layout title="Expertise — Photo Carousel">
  <div class="flex flex-col gap-12 sm:gap-16">
    {slides.length > 0 && (
      <section aria-label="Project photos">
        <div
          id="c101text-root"
          class="relative overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 select-none"
          tabindex="0"
          aria-roledescription="carousel"
        >
          <div
            id="c101text-track"
            class="flex transition-transform duration-500 ease-in-out will-change-transform"
            aria-live="polite"
          >
            {slides.map((s, i) => (
              <div
                class="min-w-full relative"
                role="group"
                aria-roledescription="slide"
                aria-label={`Photo ${i + 1} of ${slides.length}`}
                aria-hidden={i !== 0}
              >
                <img
                  src={s.src}
                  alt={s.title || s.filename}
                  class="w-full object-cover"
                  style="max-height: 30rem; object-position: center;"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
                {(s.title || s.caption) && (
                  <div class="absolute left-0 right-0 bottom-0 px-6 sm:px-8 pt-16 pb-6 bg-gradient-to-t from-black/85 via-black/60 to-transparent text-white pointer-events-none">
                    {s.title && <h3 class="text-lg sm:text-2xl font-semibold mb-1">{s.title}</h3>}
                    {s.caption && <p class="text-sm sm:text-base opacity-90 leading-snug">{s.caption}</p>}
                  </div>
                )}
              </div>
            ))}
          </div>

          {slides.length > 1 && (
            <>
              <button
                id="c101text-prev"
                aria-label="Previous photo"
                class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 hover:bg-black/75 text-white text-2xl font-bold flex items-center justify-center transition"
              >
                &lsaquo;
              </button>
              <button
                id="c101text-next"
                aria-label="Next photo"
                class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-black/50 hover:bg-black/75 text-white text-2xl font-bold flex items-center justify-center transition"
              >
                &rsaquo;
              </button>

              <div
                id="c101text-dots"
                class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 flex-wrap justify-center max-w-xs"
                role="tablist"
                aria-label="Select photo"
              >
                {slides.map((_, i) => (
                  <button
                    role="tab"
                    data-idx={String(i)}
                    aria-label={`Photo ${i + 1}`}
                    aria-selected={String(i === 0)}
                    class={[
                      'dot w-2 h-2 rounded-full transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white',
                      i === 0 ? 'bg-white scale-125' : 'bg-white/40'
                    ]}
                  />
                ))}
              </div>
            </>
          )}
        </div>
        <p id="c101text-counter" class="text-center text-sm opacity-40 mt-3">1 / {slides.length}</p>
      </section>
    )}
  </div>
</Layout>

<script>
  function initCarousel(prefix) {
    const track = document.getElementById(`${prefix}-track`);
    const root = document.getElementById(`${prefix}-root`);
    const prevBtn = document.getElementById(`${prefix}-prev`);
    const nextBtn = document.getElementById(`${prefix}-next`);
    const counter = document.getElementById(`${prefix}-counter`);
    const dots = document.querySelectorAll(`#${prefix}-dots .dot`);
    const slides = track ? Array.from(track.children) : [];

    if (!track || slides.length <= 1) return;

    const total = slides.length;
    let current = 0;
    let timer;

    function goTo(index) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== current)));
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('bg-white', active);
        d.classList.toggle('scale-125', active);
        d.classList.toggle('bg-white/40', !active);
        d.setAttribute('aria-selected', String(active));
      });
      if (counter) counter.textContent = `${current + 1} / ${total}`;
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startAuto(); });

    dots.forEach((d) =>
      d.addEventListener('click', () => { goTo(Number(d.dataset.idx)); startAuto(); })
    );

    root?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { goTo(current - 1); startAuto(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startAuto(); }
    });

    root?.addEventListener('mouseenter', () => clearInterval(timer));
    root?.addEventListener('mouseleave', startAuto);

    let touchStartX = 0;
    root?.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    root?.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        goTo(diff > 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    startAuto();
  }

  initCarousel('c101text');
</script>
