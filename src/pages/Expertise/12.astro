<script>
  function initCarousel(prefix) {
    const track = document.getElementById(`${prefix}-track`);
    const root = document.getElementById(`${prefix}-root`);
    const prevBtn = document.getElementById(`${prefix}-prev`);
    const nextBtn = document.getElementById(`${prefix}-next`);
    const counter = document.getElementById(`${prefix}-counter`);
    const titleEl = document.getElementById(`${prefix}-title`);
    const captionEl = document.getElementById(`${prefix}-caption`);
    const dataEl = document.getElementById(`${prefix}-data`);
    const captions = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
    const dots = document.querySelectorAll(`#${prefix}-dots .dot`);
    const slides = track ? Array.from(track.children) : [];
    if (!track || slides.length === 0) return;
    const total = slides.length;
    let current = 0; let timer;
    function updateCaption(i) {
      const c = captions[i] || { title: '', caption: '' };
      if (titleEl) titleEl.textContent = c.title || '';
      if (captionEl) captionEl.textContent = c.caption || '';
    }
    function goTo(index) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== current)));
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('bg-white', active);
        d.classList.toggle('scale-125', active);
        d.classList.toggle('bg-white/40', !active);
        d.setAttribute('aria-selected', String(active));
      });
      if (counter) counter.textContent = `${current + 1} / ${total}`;
      updateCaption(current);
    }
    updateCaption(0);
    if (slides.length <= 1) return;
    function startAuto() { clearInterval(timer); timer = setInterval(() => goTo(current + 1), 5000); }
    prevBtn?.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startAuto(); });
    dots.forEach((d) => d.addEventListener('click', () => { goTo(Number(d.dataset.idx)); startAuto(); }));
    root?.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { goTo(current - 1); startAuto(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startAuto(); }
    });
    root?.addEventListener('mouseenter', () => clearInterval(timer));
    root?.addEventListener('mouseleave', startAuto);
    let touchStartX = 0;
    root?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    root?.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { goTo(diff > 0 ? current + 1 : current - 1); startAuto(); }
    }, { passive: true });
    startAuto();
  }
  initCarousel('c12');
</script>
