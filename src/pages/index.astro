---
import Layout from '../layouts/Layout.astro';
import Markdown from '../components/Markdown.astro';

/**
 * Load every sensor*.{jpg,jpeg,png,webp} from weeklyfiles, then sort
 * them numerically so sensor1 → sensor2 → … → sensor14 (regardless of extension).
 *
 * import.meta.glob returns ImageMetadata objects when eager:true is set.
 * We pull `.src` (the Vite-processed, cache-busted URL) for each image.
 */
const rawImports = import.meta.glob<{ default: { src: string; width: number; height: number } }>(
  '../assets/weeklyfiles/sensor*.{jpg,jpeg,png,webp}',
  { eager: true }
);

const images: { src: string; label: string }[] = Object.entries(rawImports)
  .sort(([pathA], [pathB]) => {
    const numA = parseInt(pathA.match(/sensor(\d+)/)?.[1] ?? '0', 10);
    const numB = parseInt(pathB.match(/sensor(\d+)/)?.[1] ?? '0', 10);
    return numA - numB;
  })
  .map(([path, mod], i) => ({
    src:   mod.default.src,
    label: `Weekly work photo ${i + 1} of ${Object.keys(rawImports).length}`,
  }));

const explainer = `
Having the right team keeps your ratings high and the income coming in - learn more.
`;
---

<Layout title="Welcome to HandyMountain.">
  <h1 class="mb-10">Solutions for Twin Cities STR owners</h1>
  <Markdown content={explainer} class="mb-10 text-lg" />

  <p class="mb-14">
    <a href="https://handymsp.com/Learn More" class="btn btn-lg sm:min-w-64">Learn More</a>
  </p>

  <!-- ── Weekly Photo Carousel ───────────────────────────────────────────── -->
  {images.length > 0 && (
    <section aria-label="This week's work photos">
      <h2 class="text-xl font-semibold mb-6">This Week's Work</h2>

      <!-- Outer wrapper — clips the sliding track -->
      <div
        id="wpc-root"
        class="relative overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 select-none"
        tabindex="0"
        aria-roledescription="carousel"
      >
        <!-- Sliding track -->
        <div
          id="wpc-track"
          class="flex transition-transform duration-500 ease-in-out will-change-transform"
          aria-live="polite"
        >
          {images.map(({ src, label }, i) => (
            <div
              class="min-w-full"
              role="group"
              aria-roledescription="slide"
              aria-label={label}
              aria-hidden={i !== 0}
            >
              <img
                src={src}
                alt={label}
                class="w-full object-cover"
                style="max-height: 30rem; object-position: center;"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}
        </div>

        <!-- Prev button -->
        {images.length > 1 && (
          <button
            id="wpc-prev"
            aria-label="Previous photo"
            class="absolute left-3 top-1/2 -translate-y-1/2
                   w-10 h-10 rounded-full
                   flex items-center justify-center
                   text-2xl font-bold leading-none
                   bg-black/50 hover:bg-black/75 backdrop-blur-sm text-white
                   transition-colors duration-200
                   focus-visible:outline focus-visible:outline-2 focus-visible:outline-white"
          >
            ‹
          </button>
        )}

        <!-- Next button -->
        {images.length > 1 && (
          <button
            id="wpc-next"
            aria-label="Next photo"
            class="absolute right-3 top-1/2 -translate-y-1/2
                   w-10 h-10 rounded-full
                   flex items-center justify-center
                   text-2xl font-bold leading-none
                   bg-black/50 hover:bg-black/75 backdrop-blur-sm text-white
                   transition-colors duration-200
                   focus-visible:outline focus-visible:outline-2 focus-visible:outline-white"
          >
            ›
          </button>
        )}

        <!-- Dot indicators -->
        {images.length > 1 && (
          <div
            id="wpc-dots"
            class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 flex-wrap justify-center max-w-xs"
            role="tablist"
            aria-label="Select photo"
          >
            {images.map((_, i) => (
              <button
                role="tab"
                data-idx={String(i)}
                aria-label={`Photo ${i + 1}`}
                aria-selected={String(i === 0)}
                class={[
                  'dot w-2 h-2 rounded-full transition-all duration-300',
                  'focus-visible:outline focus-visible:outline-2 focus-visible:outline-white',
                  i === 0 ? 'bg-white scale-125' : 'bg-white/40 hover:bg-white/70',
                ].join(' ')}
              />
            ))}
          </div>
        )}
      </div>

      <!-- Photo counter -->
      <p class="text-center text-sm opacity-40 mt-3" id="wpc-counter">
        1 / {images.length}
      </p>
    </section>
  )}
</Layout>

<script>
  (() => {
    const track   = document.getElementById('wpc-track')   as HTMLElement | null;
    const root    = document.getElementById('wpc-root')    as HTMLElement | null;
    const prevBtn = document.getElementById('wpc-prev')    as HTMLButtonElement | null;
    const nextBtn = document.getElementById('wpc-next')    as HTMLButtonElement | null;
    const counter = document.getElementById('wpc-counter') as HTMLElement | null;
    const dots    = document.querySelectorAll<HTMLButtonElement>('#wpc-dots .dot');
    const slides  = document.querySelectorAll<HTMLElement>('#wpc-track > div');

    if (!track || slides.length <= 1) return;

    const total = slides.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    /* ── Core navigation ────────────────────────────────────────────── */
    function goTo(index: number) {
      current = ((index % total) + total) % total;

      // Move track
      track!.style.transform = `translateX(-${current * 100}%)`;

      // Update aria-hidden on slides
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== current)));

      // Update dots
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('bg-white',     active);
        d.classList.toggle('scale-125',    active);
        d.classList.toggle('bg-white/40', !active);
        d.setAttribute('aria-selected', String(active));
      });

      // Update counter
      if (counter) counter.textContent = `${current + 1} / ${total}`;
    }

    /* ── Auto-advance ───────────────────────────────────────────────── */
    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    /* ── Controls ───────────────────────────────────────────────────── */
    prevBtn?.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startAuto(); });

    dots.forEach(dot =>
      dot.addEventListener('click', () => {
        goTo(Number(dot.dataset.idx));
        startAuto();
      })
    );

    /* ── Keyboard (focus the carousel div to use arrow keys) ────────── */
    root?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { goTo(current - 1); startAuto(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startAuto(); }
    });

    /* ── Pause on hover ─────────────────────────────────────────────── */
    root?.addEventListener('mouseenter', () => clearInterval(timer));
    root?.addEventListener('mouseleave', startAuto);

    /* ── Touch / swipe support ──────────────────────────────────────── */
    let touchStartX = 0;
    root?.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    root?.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        goTo(diff > 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    startAuto();
  })();
</script>
