---
import Layout from '../layouts/Layout.astro';
import Markdown from '../components/Markdown.astro';

// ── Shared helper: natural filename sort ──────────────────────────────────────
// Sorts by the bare filename (not the full path), using locale-aware numeric
// ordering so "photo2" comes before "photo10", and any naming convention works.
function byFilename(pathA: string, pathB: string) {
  const name = (p: string) => p.split('/').pop() ?? p;
  return name(pathA).localeCompare(name(pathB), undefined, { numeric: true, sensitivity: 'base' });
}

// ── Carousel 1: all images in src/assets/weeklyfiles ─────────────────────────
// Any image file you drop into this folder is picked up automatically on the
// next Netlify build — no filename convention required.
const weeklyRaw = import.meta.glob<{ default: { src: string } }>(
  '../assets/weeklyfiles/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const weeklyImages = Object.entries(weeklyRaw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([, mod], i, arr) => ({
    src:   mod.default.src,
    label: `Weekly work photo ${i + 1} of ${arr.length}`,
  }));

// ── Carousel 2: all images in src/assets/skill files/caulking ────────────────
// Same deal — drop any image in, it appears. Supports up to 50 photos.
const caulkingRaw = import.meta.glob<{ default: { src: string } }>(
  '../assets/skill files/caulking/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const caulkingImages = Object.entries(caulkingRaw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([, mod], i, arr) => ({
    src:   mod.default.src,
    label: `Caulking technique photo ${i + 1} of ${arr.length}`,
  }))
  .slice(0, 50);

// ── Carousel 3: portrait images (mobile 9:16 format) ─────────────────────────
// Drop any portrait photo into src/assets/portrait files/ and it appears here.
const portraitRaw = import.meta.glob<{ default: { src: string } }>(
  '../assets/portrait files/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

const portraitImages = Object.entries(portraitRaw)
  .sort(([a], [b]) => byFilename(a, b))
  .map(([, mod], i, arr) => ({
    src:   mod.default.src,
    label: `Portrait photo ${i + 1} of ${arr.length}`,
  }));

const explainer = `
Having the right team keeps your ratings high and the income coming in - learn more.
`;
---

<Layout title="Welcome to HandyM Minneapolis - Saint Paul.">
  <h1 class="mb-10">Solutions for Twin Cities STR owners</h1>
  <Markdown content={explainer} class="mb-10 text-lg" />

  <p class="mb-14">
    <a href="https://handymsp.com/Learn More" class="btn btn-lg sm:min-w-64">Learn More</a>
  </p>

  <!-- ── Carousel 1: This Week's Work ──────────────────────────────────────── -->
  {weeklyImages.length > 0 && (
    <section class="mb-16" aria-label="This week's work photos">
      <h2 class="text-xl font-semibold mb-6">This Week's Work</h2>
      <div id="c1-root" class="relative overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 select-none" tabindex="0" aria-roledescription="carousel">
        <div id="c1-track" class="flex transition-transform duration-500 ease-in-out will-change-transform" aria-live="polite">
          {weeklyImages.map(({ src, label }, i) => (
            <div class="min-w-full" role="group" aria-roledescription="slide" aria-label={label} aria-hidden={i !== 0}>
              <img src={src} alt={label} class="w-full object-cover" style="max-height: 30rem; object-position: center;" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
            </div>
          ))}
        </div>
        {weeklyImages.length > 1 && (
          <>
            <button id="c1-prev" aria-label="Previous photo" class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full flex items-center justify-center text-2xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">‹</button>
            <button id="c1-next" aria-label="Next photo"     class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full flex items-center justify-center text-2xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">›</button>
            <div id="c1-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 flex-wrap justify-center max-w-xs" role="tablist" aria-label="Select photo">
              {weeklyImages.map((_, i) => (
                <button role="tab" data-idx={String(i)} aria-label={`Photo ${i + 1}`} aria-selected={String(i === 0)}
                  class={['dot w-2 h-2 rounded-full transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white', i === 0 ? 'bg-white scale-125' : 'bg-white/40 hover:bg-white/70'].join(' ')} />
              ))}
            </div>
          </>
        )}
      </div>
      <p id="c1-counter" class="text-center text-sm opacity-40 mt-3">1 / {weeklyImages.length}</p>
    </section>
  )}

  <!-- ── Carousel 2: Techniques ───────────────────────────────────── -->
  {caulkingImages.length > 0 && (
    <section aria-label="technique photos">
      <h2 class="text-xl font-semibold mb-6">Caulking Techniques</h2>
      <div id="c2-root" class="relative overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 select-none" tabindex="0" aria-roledescription="carousel">
        <div id="c2-track" class="flex transition-transform duration-500 ease-in-out will-change-transform" aria-live="polite">
          {caulkingImages.map(({ src, label }, i) => (
            <div class="min-w-full" role="group" aria-roledescription="slide" aria-label={label} aria-hidden={i !== 0}>
              <img src={src} alt={label} class="w-full object-cover" style="max-height: 30rem; object-position: center;" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
            </div>
          ))}
        </div>
        {caulkingImages.length > 1 && (
          <>
            <button id="c2-prev" aria-label="Previous photo" class="absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full flex items-center justify-center text-2xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">‹</button>
            <button id="c2-next" aria-label="Next photo"     class="absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full flex items-center justify-center text-2xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">›</button>
            <div id="c2-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 flex-wrap justify-center max-w-xs" role="tablist" aria-label="Select photo">
              {caulkingImages.map((_, i) => (
                <button role="tab" data-idx={String(i)} aria-label={`Photo ${i + 1}`} aria-selected={String(i === 0)}
                  class={['dot w-2 h-2 rounded-full transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white', i === 0 ? 'bg-white scale-125' : 'bg-white/40 hover:bg-white/70'].join(' ')} />
              ))}
            </div>
          </>
        )}
      </div>
      <p id="c2-counter" class="text-center text-sm opacity-40 mt-3">1 / {caulkingImages.length}</p>
    </section>
  )}

  <!-- ── Carousel 3: Portrait Photos ───────────────────────────────────────── -->
  <!-- Centered, narrow frame locked to 9:16 — optimised for phone-shot images  -->
  {portraitImages.length > 0 && (
    <section class="mt-16" aria-label="Portrait photos">
      <h2 class="text-xl font-semibold mb-6">From the Field</h2>

      <!-- Outer centering wrapper — caps width to a phone-screen column -->
      <div class="mx-auto w-full max-w-xs sm:max-w-sm">

        <div id="c3-root" class="relative overflow-hidden rounded-2xl bg-white/5 ring-1 ring-white/10 select-none" tabindex="0" aria-roledescription="carousel">

          <!-- Sliding track -->
          <div id="c3-track" class="flex transition-transform duration-500 ease-in-out will-change-transform" aria-live="polite">
            {portraitImages.map(({ src, label }, i) => (
              <div class="min-w-full" role="group" aria-roledescription="slide" aria-label={label} aria-hidden={i !== 0}>
                <!-- 9:16 aspect-ratio frame — fills perfectly with portrait shots -->
                <div style="aspect-ratio: 9 / 16; position: relative; overflow: hidden;">
                  <img
                    src={src}
                    alt={label}
                    style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center top;"
                    loading={i === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              </div>
            ))}
          </div>

          {portraitImages.length > 1 && (
            <>
              <button id="c3-prev" aria-label="Previous photo" class="absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full flex items-center justify-center text-xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">‹</button>
              <button id="c3-next" aria-label="Next photo"     class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 rounded-full flex items-center justify-center text-xl font-bold leading-none text-white bg-black/50 hover:bg-black/75 backdrop-blur-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white">›</button>
              <div id="c3-dots" class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 flex-wrap justify-center max-w-xs" role="tablist" aria-label="Select photo">
                {portraitImages.map((_, i) => (
                  <button role="tab" data-idx={String(i)} aria-label={`Photo ${i + 1}`} aria-selected={String(i === 0)}
                    class={['dot w-2 h-2 rounded-full transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-white', i === 0 ? 'bg-white scale-125' : 'bg-white/40 hover:bg-white/70'].join(' ')} />
                ))}
              </div>
            </>
          )}
        </div>

        <p id="c3-counter" class="text-center text-sm opacity-40 mt-3">1 / {portraitImages.length}</p>
      </div>
    </section>
  )}
</Layout>

<script>
  /**
   * initCarousel — boot one carousel by ID prefix.
   * Supports any number of carousels on the same page.
   */
  function initCarousel(prefix: string) {
    const track   = document.getElementById(`${prefix}-track`)   as HTMLElement | null;
    const root    = document.getElementById(`${prefix}-root`)    as HTMLElement | null;
    const prevBtn = document.getElementById(`${prefix}-prev`)    as HTMLButtonElement | null;
    const nextBtn = document.getElementById(`${prefix}-next`)    as HTMLButtonElement | null;
    const counter = document.getElementById(`${prefix}-counter`) as HTMLElement | null;
    const dots    = document.querySelectorAll<HTMLButtonElement>(`#${prefix}-dots .dot`);
    const slides  = track ? Array.from(track.children) as HTMLElement[] : [];

    if (!track || slides.length <= 1) return;

    const total = slides.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(-${current * 100}%)`;
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== current)));
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('bg-white',    active);
        d.classList.toggle('scale-125',   active);
        d.classList.toggle('bg-white/40', !active);
        d.setAttribute('aria-selected', String(active));
      });
      if (counter) counter.textContent = `${current + 1} / ${total}`;
    }

    function startAuto() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5000);
    }

    prevBtn?.addEventListener('click', () => { goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); startAuto(); });
    dots.forEach(d =>
      d.addEventListener('click', () => { goTo(Number(d.dataset.idx)); startAuto(); })
    );

    root?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { goTo(current - 1); startAuto(); }
      if (e.key === 'ArrowRight') { goTo(current + 1); startAuto(); }
    });

    root?.addEventListener('mouseenter', () => clearInterval(timer));
    root?.addEventListener('mouseleave', startAuto);

    let touchStartX = 0;
    root?.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    root?.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) { goTo(diff > 0 ? current + 1 : current - 1); startAuto(); }
    }, { passive: true });

    startAuto();
  }

  initCarousel('c1');
  initCarousel('c2');
  initCarousel('c3');
</script>
