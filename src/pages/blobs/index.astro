---
import Layout from '../../layouts/Layout.astro';
import Markdown from '../../components/Markdown.astro';
import ShapeEditor from './_components/ShapeEditor.tsx';
import { uploadDisabled } from '../../utils';

const explainer = `
Step 1:  Click RANDOMIZE then click UPLOAD. Your place in line is set. </br>
Step 2: COPY your unique JOB NUMBER (ex prospective-fly-474)</br>
Step 3: PASTE this into form below</br>
Step 4: RECEIVE a QUOTE with 5 minutes</br>
`;

const uploadDisabledText = `
User uploads are disabled in this site. To run your own and try it out: 
<a href="https://app.netlify.com/start/deploy?repository=https://github.com/netlify-templates/astro-platform-starter">
<img src="https://www.netlify.com/img/deploy/button.svg" style="display: inline;" alt="Deploy to Netlify" />
</a>
`;
---

<Layout title="Blobs">
  <h1 class="mb-10">FAST QUOTE: Get Help NOW</h1>

  <Markdown content={explainer} class="mb-12" />

  <!-- Netlify form -->
  <form
    name="contact"
    method="POST"
    data-netlify="true"
    class="mb-12 max-w-xl space-y-6"
  >
    <!-- required for Netlify form detection -->
    <input type="hidden" name="form-name" value="contact" />

    <p class="space-y-2">
      <label class="block font-semibold">
        Copy Random Job Name Here
        <input
          type="text"
          name="INQ"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Email
        <input
          type="email"
          name="email"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Mobile
        <input
          type="Mobile"
          name="Mobile"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        First Name
        <input
          type="First Name"
          name="First Name"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Exact Address
        <input
          type="address"
          name="address"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Tasks Required
        <input
          type="Task"
          name="Task"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Task Comments
        <input
          type="Comments"
          name="Comments"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
<form name="fileForm" enctype="multipart/form-data" data-netlify="true">
  <p>
    <label>
      <span>Name:</span>
      <input name="name" type="text" />
    </label>
  </p>
  <p>
    <label>
      <span>Add file:</span>
      <input name="file" type="file" />
    </label>
  </p>

  <button>Submit</button>
</form>
<p class="result"></p>

  <ShapeEditor client:load />

const explainer = `
Step 1:  Click RANDOMIZE then click UPLOAD. Your place in line is set. 
Step 2: COPY your unique JOB NUMBER (ex prospective-fly-474)
Step 3: PASTE this into form below
Step 4: RECEIVE a QUOTE with 5 minutes



In the body of your text or email, please copy this format and state 

A: the task, tasks that need to be done</br>
B: the exact location</br>


🙂.
`;
</Layout>
