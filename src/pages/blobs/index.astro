---
import Layout from '../../layouts/Layout.astro';
import Markdown from '../../components/Markdown.astro';
import ShapeEditor from './_components/ShapeEditor.tsx';
import { uploadDisabled } from '../../utils';

const explainer = `
Step 1:  Click RANDOMIZE then click UPLOAD. Your place in line is set. </br>
Step 2: COPY your unique JOB NUMBER (ex prospective-fly-474)</br>
Step 3: PASTE this into form below</br>
Step 4: RECEIVE a QUOTE with 5 minutes</br>
`;

const uploadDisabledText = `
User uploads are disabled in this site. To run your own and try it out: 
<a href="https://app.netlify.com/start/deploy?repository=https://github.com/netlify-templates/astro-platform-starter">
<img src="https://www.netlify.com/img/deploy/button.svg" style="display: inline;" alt="Deploy to Netlify" />
</a>
`;
---

<Layout title="Blobs">
  <h1 class="mb-10">FAST QUOTE: Get Help NOW</h1>

  <Markdown content={explainer} class="mb-12" />

  <!-- Netlify form -->
  <form
    name="contact1"
    method="POST"
    enctype="multipart/form-data"
    data-netlify="true"
    class="mb-12 max-w-xl space-y-6"
  >
    <!-- required for Netlify form detection -->
    <input type="hidden" name="form-name" value="contact" />

    <p class="space-y-2">
      <label class="block font-semibold">
        Copy Random Job Name Here
        <input
          type="text"
          name="INQ"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Email
        <input
          type="email"
          name="email"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Mobile
        <input
          type="tel"
          name="Mobile"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        First Name
        <input
          type="text"
          name="First Name"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Exact Address
        <input
          type="text"
          name="address"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Tasks Required
        <input
          type="text"
          name="Task"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Task Comments
        <textarea
          name="Comments"
          rows="4"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        ></textarea>
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 1
        <input
          name="fileDescription1"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Add file 1
        <input
          name="file1"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 2
        <input
          name="fileDescription2"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Add file 2
        <input
          name="file2"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 3
        <input
          name="fileDescription3"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>
    <p class="space-y-2">
      <label class="block font-semibold">
        Add file 3
        <input
          name="file3"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <button
      type="submit"
      class="rounded border border-white/40 px-6 py-2 font-semibold text-white transition hover:border-white hover:bg-white/10"
    >
      Submit
    </button>
  </form>
  <p class="result"></p>

  <ShapeEditor client:load />

  <Markdown
    content={`
 

🙂.
`}
  />
</Layout>
