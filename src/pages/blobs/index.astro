---
import Layout from '../../layouts/Layout.astro';
import Markdown from '../../components/Markdown.astro';
import ShapeEditor from './_components/ShapeEditor.tsx';
import { uploadDisabled } from '../../utils';

const explainer = `
Step 1: Fill out field below. </br>
Step 2: CREATE your unique JOB NUMBER (ex prospective-fly-474)</br>
Step 3: PASTE this number into last field of form below</br>
Step 4: RECEIVE a QUOTE within 5 minutes</br>
`;
---
<Layout title="Blobs">
  <h1 class="mb-10">FAST QUOTE: Get Help NOW</h1>
  <Markdown content={explainer} class="mb-12" />

  <!-- Netlify form -->
  <form
    name="contact1"
    method="POST"
    enctype="multipart/form-data"
    data-netlify="true"
    netlify
    class="mb-12 max-w-xl space-y-6"
  >
    <!-- form-name value MUST exactly match the form's name attribute -->
    <input type="hidden" name="form-name" value="contact1" />

    <p class="space-y-2">
      <label class="block font-semibold">
        Email
        <input
          type="email"
          name="email"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Mobile
        <input
          type="tel"
          name="mobile"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        First Name
        <input
          type="text"
          name="first-name"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Exact Address
        <input
          type="text"
          name="address"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Tasks Required
        <input
          type="text"
          name="task"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Task Comments
        <textarea
          name="comments"
          rows="4"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        ></textarea>
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 1
        <input
          name="file-description-1"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Add File 1
        <input
          name="file1"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 2
        <input
          name="file-description-2"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Add File 2
        <input
          name="file2"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Upload File Description 3
        <input
          name="file-description-3"
          type="text"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Add File 3
        <input
          name="file3"
          type="file"
          accept="image/*"
          class="mt-2 block w-full text-white file:mr-4 file:rounded file:border file:border-white/20 file:bg-white/10 file:px-3 file:py-2 file:text-white"
        />
      </label>
    </p>

    <p class="space-y-2">
      <label class="block font-semibold">
        Paste Random Job Name Here
        <input
          type="text"
          name="inq"
          class="mt-2 block w-full rounded border border-white/20 bg-white/10 px-3 py-2 text-white"
        />
      </label>
    </p>

    <button
      type="submit"
      class="rounded border border-white/40 px-6 py-2 font-semibold text-white transition hover:border-white hover:bg-white/10"
    >
      Submit
    </button>
  </form>

  <p class="result"></p>
  <ShapeEditor client:load />
  <Markdown content={`🙂`} />
</Layout>
