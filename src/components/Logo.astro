---
// Improvement idea: get actual width as props, and auto-set height by correct aspect-ratio
---

<svg
    width="220"
    height="50"
    viewBox="0 0 220 50"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="HandyMSP"
>
    <g clip-path="url(#clip0_msp3)">
        <!-- Minneapolis Skyline (solid filled) -->
        <rect x="0" y="39" width="4" height="11" fill="#fff"></rect>
        <rect x="5" y="33" width="5" height="17" fill="#fff"></rect>
        <!-- Medium-tall with spire (Capella Tower inspired) -->
        <rect x="11" y="27" width="6" height="23" fill="#fff"></rect>
        <rect x="13.5" y="20" width="2" height="7" fill="#fff"></rect>
        <!-- IDS Center – tallest, distinctive stepped/chamfered shoulders -->
        <path d="M18,50 L18,22 L20,19 L20,11 L21,9 L27,9 L28,11 L28,19 L30,22 L30,50 Z" fill="#fff"></path>
        <rect x="32" y="28" width="6" height="22" fill="#fff"></rect>
        <rect x="39" y="35" width="4" height="15" fill="#fff"></rect>

        <!-- Stone Arch Bridge – arches below roadway (sweep=0 bows upward, opening faces river) -->
        <!-- Deck / roadway -->
        <line x1="46" y1="36" x2="79" y2="36" stroke="#fff" stroke-width="1.5"></line>
        <!-- Left abutment -->
        <line x1="46" y1="36" x2="46" y2="49" stroke="#fff" stroke-width="1.5"></line>
        <!-- Pier 1 -->
        <line x1="57" y1="36" x2="57" y2="49" stroke="#fff" stroke-width="1.5"></line>
        <!-- Pier 2 -->
        <line x1="68" y1="36" x2="68" y2="49" stroke="#fff" stroke-width="1.5"></line>
        <!-- Right abutment -->
        <line x1="79" y1="36" x2="79" y2="49" stroke="#fff" stroke-width="1.5"></line>
        <!-- Arch 1 – springs at y=44, crowns near y=37 -->
        <path d="M46,44 A5.5,7 0 0 0 57,44" stroke="#fff" stroke-width="1.2" fill="none"></path>
        <!-- Arch 2 -->
        <path d="M57,44 A5.5,7 0 0 0 68,44" stroke="#fff" stroke-width="1.2" fill="none"></path>
        <!-- Arch 3 -->
        <path d="M68,44 A5.5,7 0 0 0 79,44" stroke="#fff" stroke-width="1.2" fill="none"></path>
        <!-- River / water line -->
        <line x1="46" y1="49" x2="79" y2="49" stroke="#fff" stroke-width="1"></line>

        <!-- Wordmark – all caps, baseline bottom-aligned -->
        <text
            x="85"
            y="48"
            fill="white"
            font-family="system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif"
            font-size="22"
            font-weight="700"
            letter-spacing="0"
        >HANDY MSP</text>
    </g>
    <defs>
        <clipPath id="clip0_msp3">
            <rect width="220" height="50" fill="white"></rect>
        </clipPath>
    </defs>
</svg>
